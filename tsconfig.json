{
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@src/*": ["./src/*"],
      "@web/*": ["./web/*"],
      "@plugins/*": ["./plugins/*"]
    }
  },
  "include": [
    "src/**/*",
    "scripts/**/*.ts",
    "plugins/**/*",
    "generated/**/*"
  ],
  "exclude": ["scripts/plugin-template/**/*"]
}
